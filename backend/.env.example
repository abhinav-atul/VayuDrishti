# VayuDrishti API Keys
# Get these BEFORE running the app

# WAQI - https://aqicn.org/data-platform/token/
WAQI_TOKEN=your_waqi_token_here

# OpenWeatherMap - https://openweathermap.org/api
OWM_API_KEY=your_owm_key_here

# NASA FIRMS - https://firms.modaps.eosdis.nasa.gov/api/map_key
FIRMS_MAP_KEY=your_firms_key_here

# OpenAQ - https://explore.openaq.org/register
OPENAQ_API_KEY=your_openaq_key_here

# OpenRouter - https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Earth Engine API Key (Falls back to baseline if OAuth2 isn't configured)
GEE_API_KEY=your_gee_api_key_here

# For LIVE Google Earth Engine Data, provide the absolute path to a Service Account JSON key:
# GEE_SERVICE_ACCOUNT_JSON=/absolute/path/to/your/service-account-file.json

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
